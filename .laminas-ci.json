{
    "additional_checks": [
        {
            "name": "PhpStan",
            "job": {
                "php": "8.4",
                "dependencies": "latest",
                "command": "composer require --dev phpstan/phpstan && vendor/bin/phpstan analyse"
            }
        },
        {
            "name": "PHP CS Fixer",
            "job": {
                "php": "8.4",
                "dependencies": "latest",
                "command": "composer require --dev friendsofphp/php-cs-fixer && vendor/bin/php-cs-fixer check -v --show-progress=dots --stop-on-violation --using-cache=no"
            }
        }
    ]
}